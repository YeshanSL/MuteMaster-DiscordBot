# Copy this file to ".env" and fill in your bot token.
# Never commit the real .env file or share your token with anyone.

DISCORD_TOKEN=your-bot-token-here

# Optional: how many seconds of continuous mic-mute before the [AFK] tag
# is applied. Defaults to 120 (2 minutes) if not set.
AFK_TIMEOUT_SECONDS=120

# Optional: the ID of the text channel where AFK announcements should be
# posted. Right-click a channel in Discord (Developer Mode must be on in
# Settings > Advanced) and choose "Copy Channel ID".
# If left unset, the bot falls back to the server's default/system channel.
# Optional: the ID of the text channel where AFK announcements should be
# posted. Right-click a channel in Discord (Developer Mode must be on in
# Settings > Advanced) and choose "Copy Channel ID".
# If left unset, the bot falls back to the server's default/system channel.
AFK_ANNOUNCE_CHANNEL_ID=

# Optional: how often (in minutes) the bot's Discord status message rotates.
# Defaults to 10 minutes if not set.
STATUS_ROTATE_MINUTES=10

